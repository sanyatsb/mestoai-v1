{
  "name": "gonka-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:pretty": "tsx watch src/main.ts | pino-pretty",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "set-webhook": "tsx src/scripts/set-webhook.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "eventsource-parser": "^3.0.0",
    "grammy": "^1.32.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "js-tiktoken": "^1.0.16",
    "mammoth": "^1.8.0",
    "msedge-tts": "^2.0.5",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "unpdf": "^0.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testcontainers/postgresql": "^10.16.0",
    "@testcontainers/redis": "^10.16.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.30.1",
    "ioredis-mock": "^8.9.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
